{
  "manifest_version": 3,
  "name": "UK eBay Tax Tracker",
  "version": "1.0.0",
  "description": "Track your eBay sales, fees, and HMRC tax obligations. Know exactly when you'll hit the reporting threshold.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.ebay.co.uk/*",
    "https://www.ebay.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.ebay.co.uk/*", "https://www.ebay.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
